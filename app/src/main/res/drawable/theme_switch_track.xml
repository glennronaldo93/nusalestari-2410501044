<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_checked="true">
        <shape>
            <size
                android:width="54dp"
                android:height="30dp" />

            <solid android:color="#4A3A66" />

            <corners android:radius="18dp" />

            <stroke
                android:width="1dp"
                android:color="#77678D" />
        </shape>
    </item>

    <item>
        <shape>
            <size
                android:width="54dp"
                android:height="30dp" />

            <solid android:color="#E8E1F0" />

            <corners android:radius="18dp" />

            <stroke
                android:width="1dp"
                android:color="#BEB4CA" />
        </shape>
    </item>

</selector>